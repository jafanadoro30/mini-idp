import os
import json
import time
import logging
import signal
import sys

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s - %(message)s",
)
logger = logging.getLogger("{{SERVICE_NAME_SNAKE}}")

# ── Config from env ───────────────────────────────────────────────────────────
QUEUE_URL = os.getenv("QUEUE_URL", "")
AWS_ENDPOINT = os.getenv("AWS_ENDPOINT_URL", "http://localstack:4566")
POLL_INTERVAL = int(os.getenv("POLL_INTERVAL_SECONDS", "5"))
RUNNING = True


def handle_shutdown(sig, frame):
    global RUNNING
    logger.info("Shutdown signal received, draining...")
    RUNNING = False


signal.signal(signal.SIGTERM, handle_shutdown)
signal.signal(signal.SIGINT, handle_shutdown)


def process_message(body: dict):
    """
    TODO: implement your domain logic here.
    This function is called once per SQS message.
    """
    logger.info("Processing message: %s", body)


def poll_once(sqs_client):
    if not QUEUE_URL:
        logger.warning("QUEUE_URL not set — sleeping")
        time.sleep(POLL_INTERVAL)
        return

    response = sqs_client.receive_message(
        QueueUrl=QUEUE_URL,
        MaxNumberOfMessages=10,
        WaitTimeSeconds=10,  # long polling
    )
    messages = response.get("Messages", [])
    logger.info("Received %d message(s)", len(messages))

    for msg in messages:
        try:
            body = json.loads(msg["Body"])
            process_message(body)
            sqs_client.delete_message(
                QueueUrl=QUEUE_URL,
                ReceiptHandle=msg["ReceiptHandle"],
            )
        except Exception as exc:  # noqa: BLE001
            logger.error("Failed to process message: %s", exc)


def main():
    try:
        import boto3
        sqs = boto3.client("sqs", endpoint_url=AWS_ENDPOINT)
    except ImportError:
        logger.error("boto3 not installed — add it to requirements.txt")
        sys.exit(1)

    logger.info("{{SERVICE_NAME}} worker started. Queue: %s", QUEUE_URL or "(not set)")
    while RUNNING:
        poll_once(sqs)

    logger.info("Worker stopped cleanly.")


if __name__ == "__main__":
    main()
