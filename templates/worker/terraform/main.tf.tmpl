/**
 * Terraform module — {{SERVICE_NAME}} (worker)
 * Auto-generated by IDP scaffold on {{DATE}}
 *
 * Resources provisioned:
 *   - SQS queue     : main event queue (long polling enabled)
 *   - SQS DLQ       : dead-letter queue (max 3 retries before parking)
 *   - SSM parameter : runtime configuration (queue URL injected at startup)
 *
 * Targets LocalStack for local development.
 * For production: remove the endpoint overrides and configure real AWS credentials.
 */

terraform {
  required_version = ">= 1.5"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region                      = var.aws_region
  access_key                  = "test"
  secret_key                  = "test"
  skip_credentials_validation = true
  skip_metadata_api_check     = true
  skip_requesting_account_id  = true

  endpoints {
    sqs = var.localstack_endpoint
    ssm = var.localstack_endpoint
  }
}

# ── SQS Dead-Letter Queue ─────────────────────────────────────────────────────
resource "aws_sqs_queue" "dead_letter" {
  name                      = "${var.service_name}-dlq"
  message_retention_seconds = 1209600  # 14 days — long retention for investigation
  tags                      = local.common_tags
}

# ── SQS Main Queue ────────────────────────────────────────────────────────────
resource "aws_sqs_queue" "main" {
  name                       = "${var.service_name}-queue"
  visibility_timeout_seconds = 30
  message_retention_seconds  = 86400   # 1 day
  receive_wait_time_seconds  = 10      # long polling — reduces empty receives

  redrive_policy = jsonencode({
    deadLetterTargetArn = aws_sqs_queue.dead_letter.arn
    maxReceiveCount     = 3
  })

  tags = local.common_tags
}

# ── SSM Parameter (runtime config — queue URL injected here) ─────────────────
resource "aws_ssm_parameter" "config" {
  name  = "/${var.environment}/${var.service_name}/config"
  type  = "String"
  value = jsonencode({
    queue_url = aws_sqs_queue.main.url
    dlq_url   = aws_sqs_queue.dead_letter.url
  })
  tags = local.common_tags
}

locals {
  common_tags = {
    Service     = var.service_name
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}
